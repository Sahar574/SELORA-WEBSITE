<script>
  // Nav scroll
  window.addEventListener('scroll', () => {
    document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 60);
  });

  // CAROUSEL
  const track = document.getElementById('carouselTrack');
  const dotsContainer = document.getElementById('carouselDots');
  const cards = Array.from(track.querySelectorAll('.testimonial-card'));
  const total = cards.length;
  let current = 0;
  let autoTimer;

  function getPerPage() { return window.innerWidth <= 768 ? 1 : 2; }
  function getPages() { return Math.ceil(total / getPerPage()); }

  function getCardWidth() {
    const wrap = track.parentElement;
    const perPage = getPerPage();
    return (wrap.offsetWidth - (perPage - 1) * 16) / perPage;
  }

  function setCardWidths() {
    const w = getCardWidth();
    cards.forEach(c => { c.style.flex = '0 0 ' + w + 'px'; c.style.minWidth = w + 'px'; });
  }

  function buildDots() {
    dotsContainer.innerHTML = '';
    const pages = getPages();
    for (let i = 0; i < pages; i++) {
      const d = document.createElement('div');
      d.className = 'dot' + (i === 0 ? ' active' : '');
      d.addEventListener('click', () => goTo(i));
      dotsContainer.appendChild(d);
    }
  }

  function goTo(page) {
    const pages = getPages();
    const perPage = getPerPage();
    current = (page + pages) % pages;
    const cardW = getCardWidth();
    const offset = current * perPage * (cardW + 16);
    track.style.transform = 'translateX(-' + offset + 'px)';
    dotsContainer.querySelectorAll('.dot').forEach((d, i) => d.classList.toggle('active', i === current));
    resetAuto();
  }

  function resetAuto() {
    clearInterval(autoTimer);
    autoTimer = setInterval(() => goTo(current + 1), 3500);
  }

  document.getElementById('prevBtn').addEventListener('click', () => goTo(current - 1));
  document.getElementById('nextBtn').addEventListener('click', () => goTo(current + 1));
  window.addEventListener('resize', () => { setCardWidths(); buildDots(); goTo(0); });

  setCardWidths();
  buildDots();
  resetAuto();
</script>

<!-- POLICIES MODAL -->
<div class="policies-overlay" id="policiesOverlay" onclick="if(event.target===this)closePolicies()">
  <div class="policies-modal">
    <button class="policies-close" onclick="closePolicies()">✕</button>
    <p class="policies-modal-title">Selora Aesthetics</p>
    <h2>Booking Policies</h2>
    <div class="policies-grid">
      <div class="policy-block">
        <h4>Booking Appointments</h4>
        <ul>
          <li>All appointments must be scheduled in advance.</li>
          <li>A deposit may be required to secure your booking (non-refundable, but transferable if rescheduled within the policy timeframe).</li>
          <li>Same-day appointments are based on availability.</li>
        </ul>
      </div>
      <div class="policy-block">
        <h4>Cancellations & Rescheduling</h4>
        <ul>
          <li>Please provide 24–48 hours' notice if you need to reschedule or cancel.</li>
          <li>Cancellations with less than 24 hours' notice, or no-shows, will result in a forfeited deposit.</li>
          <li>Arrivals later than 15 minutes may require rescheduling.</li>
        </ul>
      </div>
      <div class="policy-block">
        <h4>Payments</h4>
        <ul>
          <li>Payments are accepted via cash or e-transfer at this time.</li>
          <li>All deposits are applied toward your treatment cost.</li>
          <li>Packages and memberships are non-refundable but may be transferred to another service.</li>
        </ul>
      </div>
      <div class="policy-block">
        <h4>Health & Safety</h4>
        <ul>
          <li>Please arrive with clean skin (no makeup on the treatment area).</li>
          <li>Notify me of any medical conditions, medications, or recent procedures before your appointment.</li>
          <li>If you are sick or feeling unwell, please reschedule.</li>
        </ul>
      </div>
      <div class="policy-block">
        <h4>Results & Aftercare</h4>
        <ul>
          <li>Results vary per individual, and consistency is key.</li>
          <li>Aftercare instructions will be provided — please follow them carefully.</li>
          <li>Selora Aesthetics is not liable for results compromised due to not following pre- and post-care guidelines.</li>
        </ul>
      </div>
    </div>
    <div class="policies-footer-text">
      <p>My goal is to provide a relaxing, professional, and welcoming environment.</p>
      <p>Kindly respect these policies so that I can continue to give every client the best possible care.</p>
      <p class="policies-closing">✦ Thank you for choosing Selora Aesthetics — I look forward to helping you feel confident and radiant in your own skin. ✦</p>
    </div>
  </div>
</div>

<script>
  function closePolicies() {
    document.getElementById('policiesOverlay').classList.remove('open');
  }
  document.addEventListener('keydown', e => { if(e.key === 'Escape') closePolicies(); });
</script>
</body>
</html>
