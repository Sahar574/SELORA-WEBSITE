<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Selora Aesthetics — Luxury Medical Spa · Woodbridge, Ontario</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Jost:wght@200;300;400&family=Playfair+Display:wght@300;400&display=swap" rel="stylesheet">
<style>
  :root {
    --deep: #1a1612;
    --mid: #6b5e52;
    --warm-white: #f7f3ee;
    --cream: #f7f3ee;
    --gold: #bfa980;
    --gold-light: #d4c4a8;
    --border: rgba(191,169,128,0.2);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Jost', sans-serif;
    background: var(--cream);
    color: var(--deep);
    overflow-x: hidden;
  }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 12px 60px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    background: rgba(247,243,238,0.96);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    transition: padding 0.4s ease;
  }
  nav.scrolled { padding: 10px 60px; }
  .nav-social { grid-column: 1; justify-self: start; display: flex; gap: 16px; align-items: center; }
  .nav-social a { color: var(--mid); text-decoration: none; transition: color 0.3s; display: flex; align-items: center; }
  .nav-social a:hover { color: var(--gold); }
  .nav-logo { grid-column: 2; justify-self: center; text-decoration: none; }
  .nav-logo-text {
    font-family: 'Playfair Display', serif;
    font-size: 36px;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--deep);
    display: inline-block;
  }
  .nav-links { grid-column: 3; justify-self: end; display: flex; gap: 44px; list-style: none; }
  .nav-links a {
    font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--deep); text-decoration: none; font-weight: 400; transition: color 0.3s;
  }
  .nav-links a:hover { color: var(--gold); }
  .hamburger { display: none; grid-column: 3; justify-self: end; flex-direction: column; gap: 5px; cursor: pointer; background: none; border: none; padding: 4px; }
  .hamburger span { display: block; width: 24px; height: 2px; background: var(--deep); transition: all 0.3s; }

  /* Floating Book Now */
  .floating-book {
    position: fixed; bottom: 32px; right: 32px;
    z-index: 99;
    background: var(--deep);
    color: var(--gold-light);
    font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase;
    text-decoration: none; font-weight: 300;
    padding: 14px 28px;
    border: 1px solid rgba(191,169,128,0.3);
    transition: all 0.3s ease;
  }
  .floating-book:hover { background: var(--gold); color: var(--deep); }

  /* HERO */
  #hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 0;
    overflow: hidden;
  }
  .hero-left {
    display: flex; flex-direction: column; align-items: center;
    justify-content: center; text-align: center;
    padding: 120px 80px 80px;
    position: relative; z-index: 2;
    width: 100%; max-width: 800px;
  }
  .hero-eyebrow {
    font-size: 10px; letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--gold); font-weight: 300; margin-bottom: 28px; text-align: center;
  }
  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(40px, 4.5vw, 66px);
    font-weight: 300; line-height: 1.08; letter-spacing: -0.02em;
    color: var(--deep); margin-bottom: 28px;
  }
  .hero-title em { font-style: italic; color: var(--gold); }
  .hero-desc {
    font-size: 15px; font-weight: 300; line-height: 1.8;
    color: var(--mid); max-width: 480px; margin-bottom: 44px; text-align: center;
  }
  .hero-actions { display: flex; gap: 20px; align-items: center; flex-wrap: wrap; justify-content: center; }

  .btn-primary {
    display: inline-block;
    background: var(--deep); color: var(--gold-light);
    font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase;
    text-decoration: none; font-weight: 300;
    padding: 16px 36px;
    border: 1px solid transparent;
    position: relative; overflow: hidden;
    transition: color 0.4s;
  }
  .btn-primary::after {
    content: ''; position: absolute;
    inset: 0; background: var(--gold);
    transform: translateX(-101%); transition: transform 0.4s ease;
    z-index: 0;
  }
  .btn-primary span, .btn-primary { position: relative; z-index: 1; }
  .btn-primary:hover { color: var(--deep); }
  .btn-primary:hover::after { transform: translateX(0); }

  .btn-ghost {
    display: inline-block;
    font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--mid); text-decoration: none; font-weight: 300;
    padding: 16px 0;
    border-bottom: 1px solid var(--border);
    transition: color 0.3s, border-color 0.3s;
  }
  .btn-ghost:hover { color: var(--deep); border-color: var(--deep); }

  .hero-right {
    position: absolute; inset: 0; z-index: 0;
    opacity: 0; animation: fadeIn 1.4s ease 0.3s forwards;
  }
  .hero-right::after {
    content: ''; position: absolute; inset: 0;
    background: rgba(247,243,238,0.72);
    z-index: 1;
  }
  .hero-image-wrap { position: absolute; inset: 0; overflow: hidden; }
  .hero-image-wrap img { width: 100%; height: 100%; object-fit: cover; object-position: center; display: block; }

  @keyframes fadeIn { from { opacity: 0; transform: translateX(20px); } to { opacity: 1; transform: translateX(0); } }

  /* ABOUT */
  #about {
    background: var(--warm-white);
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 420px;
    overflow: hidden;
  }
  .about-image-col {
    position: relative;
    overflow: hidden;
  }
  .about-image-col::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(247,243,238,0.55);
    z-index: 1;
  }
  .about-image-col img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }
  .about-pitch {
    background: var(--warm-white);
    padding: 80px 60px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  .about-pitch .section-label { justify-content: center; }
  .about-pitch .section-label::before { display: none; }
  .about-pitch .ornament { max-width: 300px; margin: 0 auto 24px; }

  /* SECTION LABELS */
  .section-label {
    font-size: 10px; letter-spacing: 0.35em; text-transform: uppercase;
    color: var(--gold); font-weight: 300;
    display: flex; align-items: center; gap: 14px; margin-bottom: 20px;
  }
  .section-label::before {
    content: ''; display: block; width: 32px; height: 1px; background: var(--gold); opacity: 0.5;
  }
  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(32px, 3.5vw, 52px);
    font-weight: 300; line-height: 1.1; letter-spacing: -0.01em;
    color: var(--deep); margin-bottom: 32px;
  }
  .section-title em { font-style: italic; color: var(--gold); }
  .section-body {
    font-size: 15px; font-weight: 300; line-height: 1.9; color: var(--mid);
  }

  /* ORNAMENT */
  .ornament { display: flex; align-items: center; gap: 12px; margin-bottom: 28px; }
  .ornament-line { flex: 1; height: 1px; background: var(--gold); opacity: 0.3; }
  .ornament-diamond { width: 6px; height: 6px; background: var(--gold); transform: rotate(45deg); opacity: 0.6; flex-shrink: 0; }

  /* TESTIMONIALS */
  #testimonials {
    padding: 120px 80px;
    background: var(--deep);
    overflow: hidden;
  }
  .testimonials-header {
    display: flex; justify-content: space-between; align-items: flex-start;
    margin-bottom: 64px;
  }
  .testimonials-header .section-label { color: rgba(191,169,128,0.7); }
  .testimonials-header .section-label::before { background: rgba(191,169,128,0.4); }
  .testimonials-header .section-title { color: var(--warm-white); margin-bottom: 0; }
  .testimonials-header .section-title em { color: var(--gold); }

  .rating-badge { text-align: right; }
  .rating-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: 48px; font-weight: 300; color: var(--warm-white); line-height: 1;
  }
  .rating-stars-row { display: flex; gap: 4px; justify-content: flex-end; margin: 8px 0 6px; }
  .rating-star {
    width: 10px; height: 10px; background: var(--gold);
    clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
  }
  .rating-label { font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(191,169,128,0.6); font-weight: 300; }

  .carousel-wrap { position: relative; overflow: hidden; }
  .carousel-track { display: flex; gap: 16px; transition: transform 0.6s cubic-bezier(0.4,0,0.2,1); will-change: transform; }

  .testimonial-card {
    position: relative;
    flex: 0 0 calc(50% - 8px); min-width: calc(50% - 8px);
    background: rgba(255,255,255,0.035);
    border: 1px solid rgba(191,169,128,0.18);
    padding: 44px 40px 36px;
    transition: background 0.4s, border-color 0.4s, transform 0.4s;
    overflow: hidden;
  }
  .testimonial-card::before {
    content: '"'; position: absolute; top: 16px; right: 28px;
    font-family: 'Cormorant Garamond', serif; font-size: 100px; line-height: 1;
    color: rgba(191,169,128,0.12); pointer-events: none;
  }
  .testimonial-card::after {
    content: ''; position: absolute; bottom: 0; left: 0;
    width: 0; height: 2px;
    background: linear-gradient(90deg, var(--gold), transparent);
    transition: width 0.5s ease;
  }
  .testimonial-card:hover { background: rgba(191,169,128,0.07); border-color: rgba(191,169,128,0.35); transform: translateY(-4px); }
  .testimonial-card:hover::after { width: 100%; }

  .testimonial-stars { display: flex; gap: 4px; margin-bottom: 20px; }
  .star {
    width: 10px; height: 10px; background: var(--gold);
    clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
  }
  .testimonial-quote {
    font-family: 'Cormorant Garamond', serif; font-size: 17px; font-weight: 300;
    font-style: italic; line-height: 1.7; color: rgba(247,243,238,0.88);
    margin-bottom: 28px; position: relative; z-index: 1;
  }
  .testimonial-divider { width: 32px; height: 1px; background: var(--gold); opacity: 0.4; margin-bottom: 20px; }
  .testimonial-author { display: flex; align-items: center; gap: 14px; }
  .author-avatar {
    width: 38px; height: 38px; border-radius: 50%;
    background: linear-gradient(135deg, rgba(191,169,128,0.5) 0%, rgba(140,123,110,0.4) 100%);
    border: 1px solid rgba(191,169,128,0.35);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Cormorant Garamond', serif; font-size: 13px;
    color: var(--gold-light); font-weight: 300; flex-shrink: 0;
  }
  .author-name { font-size: 12px; font-weight: 300; color: rgba(247,243,238,0.9); letter-spacing: 0.06em; }
  .author-detail { font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold); margin-top: 4px; font-weight: 300; opacity: 0.7; }

  .carousel-controls { display: flex; align-items: center; justify-content: center; gap: 32px; margin-top: 56px; }
  .carousel-btn {
    width: 48px; height: 48px; border: 1px solid rgba(191,169,128,0.3);
    background: transparent; color: var(--gold); font-size: 18px;
    cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.3s ease;
  }
  .carousel-btn:hover { background: var(--gold); color: var(--deep); border-color: var(--gold); }
  .carousel-dots { display: flex; gap: 10px; }
  .dot { width: 6px; height: 6px; background: rgba(191,169,128,0.3); transition: all 0.3s; cursor: pointer; }
  .dot.active { background: var(--gold); width: 24px; }

  /* CONTACT */
  #contact {
    padding: 120px 80px;
    background: var(--cream);
    text-align: center;
  }
  .contact-info { max-width: 560px; margin: 0 auto; }
  .contact-info .section-label { justify-content: center; }
  .contact-info .section-label::before { display: none; }
  .contact-details { margin-top: 40px; display: flex; flex-direction: column; gap: 24px; align-items: center; }
  .contact-item { align-items: center; }
  .contact-item { display: flex; flex-direction: column; gap: 6px; }
  .contact-item-label { font-size: 9px; letter-spacing: 0.25em; text-transform: uppercase; color: var(--gold); font-weight: 300; }
  .contact-item-value { font-size: 15px; font-weight: 300; color: var(--deep); }
  .contact-item-value a { color: var(--deep); text-decoration: none; transition: color 0.3s; }
  .contact-item-value a:hover { color: var(--gold); }

  /* MAP */
  #map-section { padding: 0 0 0 0; background: var(--warm-white); }
  .map-header { padding: 80px 80px 40px; text-align: center; }
  .map-header .section-label { justify-content: center; }
  .map-header .section-label::before { display: none; }
  .map-header .section-title { margin-bottom: 12px; }
  .map-address { font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--mid); font-weight: 300; }
  .map-frame { width: 100%; height: 460px; border: none; overflow: hidden; position: relative; filter: grayscale(20%) contrast(1.02); }
  .map-frame iframe { width: 100%; height: 100%; border: 0; display: block; }
  .map-directions {
    display: block; text-align: center; padding: 28px;
    font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--gold); text-decoration: none; font-weight: 300; transition: color 0.3s;
  }
  .map-directions:hover { color: var(--deep); }

  /* FOOTER */
  footer {
    background: var(--deep); color: rgba(247,243,238,0.5);
    padding: 48px 80px;
    display: grid; grid-template-columns: 1fr auto 1fr; align-items: center;
    border-top: 1px solid rgba(191,169,128,0.15);
  }
  .footer-copy { font-size: 11px; letter-spacing: 0.15em; font-weight: 300; justify-self: start; }
  .footer-logo { font-family: 'Playfair Display', serif; font-size: 22px; font-weight: 400; letter-spacing: -0.02em; color: rgba(247,243,238,0.6); justify-self: center; }
  .footer-social { display: flex; gap: 20px; align-items: center; justify-self: end; }
  .footer-social a { color: rgba(247,243,238,0.4); text-decoration: none; transition: color 0.3s; display: flex; align-items: center; }
  .footer-social a:hover { color: var(--gold); }

  /* MOBILE */
  @media (max-width: 768px) {
    nav { padding: 20px 24px; grid-template-columns: auto 1fr auto; }
    nav.scrolled { padding: 14px 24px; }
    .nav-social { gap: 12px; }
    .nav-logo { grid-column: 2; justify-self: center; }
    .nav-logo-text { font-size: 24px; }
    .nav-links { display: none; }
    .nav-links.open {
      display: flex; flex-direction: column;
      position: absolute; top: 100%; left: 0; right: 0;
      background: rgba(247,243,238,0.98);
      padding: 20px 24px 28px; gap: 20px;
      border-bottom: 1px solid var(--border);
    }
    .hamburger { display: flex; grid-column: 3; justify-self: end; }

    .floating-book { bottom: 20px; right: 16px; font-size: 10px; padding: 12px 20px; }

    #hero { min-height: 75svh; }
    .hero-left { padding: 100px 28px 60px; }
    .hero-right { position: absolute; inset: 0; }
    .hero-title { font-size: 28px; }
    .hero-desc { font-size: 13px; }
    .hero-actions { flex-direction: column; align-items: flex-start; gap: 12px; }
    .btn-primary { font-size: 10px; padding: 12px 20px; }

    #about { grid-template-columns: 1fr; min-height: unset; }
    .about-image-col { min-height: 200px; width: 75%; margin: 0 auto; order: 2; }
    .about-image-col img { object-position: center center; }
    .about-pitch { padding: 40px 24px 32px; order: 1; }
    .about-pitch .section-title { font-size: 28px; }
    .about-pitch .section-body { font-size: 13px; line-height: 1.7; }
    .section-title { font-size: 20px; margin-bottom: 16px; }
    .section-body { font-size: 11px; line-height: 1.6; }

    #testimonials { padding: 80px 24px; }
    .testimonials-header { flex-direction: column; gap: 24px; }
    .rating-badge { text-align: left; }
    .rating-stars-row { justify-content: flex-start; }
    .testimonial-card { flex: 0 0 100%; min-width: 100%; padding: 32px 24px; }

    #contact { padding: 60px 28px; }

    #map-section { padding: 0; }
    .map-header { padding: 60px 28px 32px; }
    .map-frame { height: 280px; }
    .map-frame iframe { width: 100% !important; height: 100% !important; display: block; }

    footer { flex-direction: column; gap: 24px; padding: 48px 24px 40px; text-align: center; }
    .footer-social { justify-content: center; }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    nav { padding: 22px 36px; }
    .nav-links { gap: 28px; }
    .hero-left { padding: 120px 48px 80px; }
    .hero-title { font-size: 42px; }
    #about { padding: 100px 48px; }
    #testimonials { padding: 100px 48px; }
    .testimonial-card { flex: 0 0 calc(50% - 8px); min-width: calc(50% - 8px); }
    footer { padding: 48px 48px; }
  }

  .policies-header {
    text-align: center;
    margin-bottom: 64px;
  }
  .policies-header .section-label { justify-content: center; }
  .policies-header .section-label::before { display: none; }
  .policies-header .section-title { margin-bottom: 0; }
  .policies-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px 80px;
    max-width: 900px;
    margin: 0 auto 64px;
  }
  .policy-block h4 {
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--deep);
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
  }
  .policy-block ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .policy-block ul li {
    font-size: 13px;
    font-weight: 300;
    line-height: 1.7;
    color: var(--mid);
    padding-left: 16px;
    position: relative;
  }
  .policy-block ul li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--gold);
    font-size: 11px;
  }
  .policies-footer {
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
    padding-top: 48px;
    border-top: 1px solid var(--border);
  }
  .policies-footer p {
    font-size: 14px;
    font-weight: 300;
    line-height: 1.8;
    color: var(--mid);
    margin-bottom: 16px;
  }
  .policies-footer .policies-closing {
    font-family: 'Cormorant Garamond', serif;
    font-size: 16px;
    font-style: italic;
    color: var(--gold);
    font-weight: 300;
  }

  @media (max-width: 768px) {
    #policies { padding: 80px 28px; }
    .policies-grid { grid-template-columns: 1fr; gap: 36px; }
  }

  /* POLICIES TAB */
  .policies-tab-btn {
    display: block;
    text-align: center;
    margin: 0 auto;
    background: none;
    border: 1px solid var(--gold);
    color: var(--gold);
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 300;
    padding: 14px 36px;
    cursor: pointer;
    transition: all 0.3s;
    margin-top: 40px;
  }
  .policies-tab-btn:hover { background: var(--gold); color: var(--deep); }

  .policies-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(26,22,18,0.7);
    z-index: 200;
    backdrop-filter: blur(4px);
    align-items: center;
    justify-content: center;
    padding: 20px;
  }
  .policies-overlay.open { display: flex; }

  .policies-modal {
    background: var(--cream);
    max-width: 780px;
    width: 100%;
    max-height: 85vh;
    overflow-y: auto;
    padding: 56px 56px 48px;
    position: relative;
  }
  .policies-modal::-webkit-scrollbar { width: 4px; }
  .policies-modal::-webkit-scrollbar-thumb { background: var(--gold); opacity: 0.4; }

  .policies-close {
    position: absolute;
    top: 20px; right: 24px;
    background: none; border: none;
    font-size: 22px; color: var(--mid);
    cursor: pointer; line-height: 1;
    transition: color 0.3s;
  }
  .policies-close:hover { color: var(--deep); }

  .policies-modal-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 13px;
    font-style: italic;
    color: var(--gold);
    letter-spacing: 0.1em;
    margin-bottom: 4px;
    font-weight: 300;
  }
  .policies-modal h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 36px;
    font-weight: 300;
    color: var(--deep);
    letter-spacing: -0.01em;
    margin-bottom: 40px;
    line-height: 1.1;
  }
  .policies-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px 60px;
    margin-bottom: 48px;
  }
  .policy-block h4 {
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--deep);
    margin-bottom: 14px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
  }
  .policy-block ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }
  .policy-block ul li {
    font-size: 13px; font-weight: 300; line-height: 1.7;
    color: var(--mid); padding-left: 16px; position: relative;
  }
  .policy-block ul li::before { content: '—'; position: absolute; left: 0; color: var(--gold); font-size: 11px; }

  .policies-footer-text {
    text-align: center;
    padding-top: 36px;
    border-top: 1px solid var(--border);
  }
  .policies-footer-text p { font-size: 13px; font-weight: 300; line-height: 1.8; color: var(--mid); margin-bottom: 12px; }
  .policies-closing {
    font-family: 'Cormorant Garamond', serif;
    font-size: 15px; font-style: italic; color: var(--gold); font-weight: 300;
  }

  @media (max-width: 768px) {
    .policies-modal { padding: 48px 24px 40px; }
    .policies-grid { grid-template-columns: 1fr; gap: 32px; }
  }
</style>
